generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  READER
  WRITER
}

model User {
  id                              String   @id @default(cuid())
  name                            String
  email                           String   @unique
  passwordHash                    String
  role                            UserRole @default(READER)
  emailVerified                   DateTime?
  emailVerificationToken          String?  @unique
  emailVerificationTokenExpiresAt DateTime?
  passwordResetToken              String?  @unique
  passwordResetTokenExpiresAt     DateTime?
  onboardingCompleted             Boolean  @default(false)
  readerGenres                    String?
  writerGenres                    String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  sessions      Session[]
  books         Book[]         @relation("AuthoredBooks")
  purchases     Purchase[]     @relation("PurchasedBooks")
  reviews       Review[]       @relation("WrittenReviews")
  payouts       Payout[]
  payoutMethod  PayoutMethod?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Book {
  id                 String     @id @default(cuid())
  title              String
  description        String
  genre              String
  language           String
  priceCents         Int        @default(0)
  discountPriceCents Int?
  coverUrl           String?
  fileUrl            String?
  status      BookStatus @default(DRAFT)
  authorId    String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  author    User       @relation("AuthoredBooks", fields: [authorId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  reviews   Review[]

  @@map("books")
}

model Review {
  id        String   @id @default(cuid())
  bookId    String
  readerId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reader User @relation("WrittenReviews", fields: [readerId], references: [id], onDelete: Cascade)

  @@unique([readerId, bookId])
  @@map("reviews")
}

model Purchase {
  id          String   @id @default(cuid())
  readerId    String
  bookId      String
  amountPaid  Int
  createdAt   DateTime @default(now())

  reader User @relation("PurchasedBooks", fields: [readerId], references: [id], onDelete: Cascade)
  book   Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([readerId, bookId])
  @@map("purchases")
}

enum PayoutStatus {
  PROCESSING
  COMPLETED
  FAILED
}

model Payout {
  id          String       @id @default(cuid())
  authorId    String
  amountCents Int
  destination String
  status      PayoutStatus @default(PROCESSING)
  initiatedAt DateTime     @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("payouts")
}

enum PayoutMethodType {
  ECOCASH
  BANK_TRANSFER
}

model PayoutMethod {
  id            String           @id @default(cuid())
  userId        String           @unique
  type          PayoutMethodType
  phoneNumber   String?
  bankName      String?
  accountName   String?
  accountNumber String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payout_methods")
}
