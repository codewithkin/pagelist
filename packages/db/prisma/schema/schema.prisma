generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  READER
  WRITER
}

model User {
  id                              String   @id @default(cuid())
  name                            String
  email                           String   @unique
  passwordHash                    String
  role                            UserRole @default(READER)
  emailVerified                   DateTime?
  emailVerificationToken          String?  @unique
  emailVerificationTokenExpiresAt DateTime?
  onboardingCompleted             Boolean  @default(false)
  readerGenres                    String?
  writerGenres                    String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  sessions Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
