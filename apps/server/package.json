{
  "name": "server",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@pagelist/auth": "workspace:*",
    "@pagelist/db": "workspace:*",
    "@pagelist/env": "workspace:*",
    "@pagelist/payments": "workspace:*",
    "@pagelist/upload": "workspace:*",
    "dotenv": "catalog:",
    "hono": "^4.8.2",
    "nodemailer": "^6.9.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsdown": "^0.16.5",
    "@pagelist/config": "workspace:*",
    "@types/bun": "catalog:"
  }
}