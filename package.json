{
  "name": "pagelist",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@prisma/client": "^7.2.0",
      "@types/react-dom": "^19.2.3"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @pagelist/db db:push",
    "db:studio": "turbo -F @pagelist/db db:studio",
    "db:generate": "turbo -F @pagelist/db db:generate",
    "db:migrate": "turbo -F @pagelist/db db:migrate"
  },
  "packageManager": "bun@1.3.5",
  "dependencies": {
    "dotenv": "catalog:",
    "zod": "catalog:",
    "@pagelist/env": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/bun": "catalog:",
    "@pagelist/config": "workspace:*",
    "turbo": "^2.8.12"
  }
}
